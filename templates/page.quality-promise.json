        "liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Our Standards – FéraFive | Quality Promise</title>\n  <meta name=\"description\" content=\"FéraFive's quality promise — FDA-licensed, stability-tested, GMP-certified manufacturing. Discover the science and intention behind every product.\">\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Montserrat:wght@300;400;500;600&display=swap\" rel=\"stylesheet\">\n  <style>\n    /* ═══════════════════════════════════════\n       RESET & BASE\n    ═══════════════════════════════════════ */\n    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }\n\n    :root {\n      --color-bg: #FDFBF8;\n      --color-bg-warm: #F7F3ED;\n      --color-bg-deep: #EDE8E0;\n      --color-text: #2C2824;\n      --color-text-muted: #6B6560;\n      --color-text-light: #9A9490;\n      --color-accent: #C8A87C;\n      --color-accent-dark: #A68B64;\n      --color-line: #DDD6CC;\n      --color-white: #FFFFFF;\n      --color-badge-green: #4A6741;\n      --color-badge-green-bg: #EFF5ED;\n      --font-display: 'Cormorant Garamond', Georgia, 'Times New Roman', serif;\n      --font-body: 'Montserrat', 'Helvetica Neue', Arial, sans-serif;\n      --max-width: 1200px;\n      --section-spacing: 120px;\n    }\n\n    html { scroll-behavior: smooth; font-size: 16px; }\n    body {\n      font-family: var(--font-body);\n      background: var(--color-bg);\n      color: var(--color-text);\n      line-height: 1.7;\n      font-weight: 300;\n      -webkit-font-smoothing: antialiased;\n      overflow-x: hidden;\n    }\n\n    a { color: inherit; text-decoration: none; }\n    img { max-width: 100%; display: block; }\n\n    .container {\n      max-width: var(--max-width);\n      margin: 0 auto;\n      padding: 0 40px;\n    }\n\n    /* ═══════════════════════════════════════\n       ANNOUNCEMENT BAR (matches site)\n    ═══════════════════════════════════════ */\n    .announcement-bar {\n      background: var(--color-text);\n      color: var(--color-white);\n      text-align: center;\n      padding: 10px 20px;\n      font-size: 12px;\n      letter-spacing: 1.5px;\n      text-transform: uppercase;\n      font-weight: 400;\n    }\n\n    /* ═══════════════════════════════════════\n       HEADER / NAV (simplified match)\n    ═══════════════════════════════════════ */\n    .site-header {\n      background: var(--color-bg);\n      border-bottom: 1px solid var(--color-line);\n      padding: 18px 0;\n      position: sticky;\n      top: 0;\n      z-index: 100;\n    }\n    .site-header .container {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n    }\n    .logo-text {\n      font-family: var(--font-display);\n      font-size: 28px;\n      font-weight: 400;\n      letter-spacing: 2px;\n      color: var(--color-text);\n    }\n    .logo-text span { font-style: italic; }\n    .nav-links {\n      display: flex;\n      gap: 36px;\n      list-style: none;\n    }\n    .nav-links a {\n      font-size: 13px;\n      letter-spacing: 1px;\n      text-transform: uppercase;\n      font-weight: 400;\n      color: var(--color-text-muted);\n      transition: color 0.3s;\n      position: relative;\n    }\n    .nav-links a::after {\n      content: '';\n      position: absolute;\n      bottom: -4px;\n      left: 0;\n      width: 0;\n      height: 1px;\n      background: var(--color-accent);\n      transition: width 0.4s ease;\n    }\n    .nav-links a:hover { color: var(--color-text); }\n    .nav-links a:hover::after { width: 100%; }\n    .nav-links a.active { color: var(--color-text); }\n    .nav-links a.active::after { width: 100%; }\n\n    .mobile-toggle {\n      display: none;\n      background: none;\n      border: none;\n      cursor: pointer;\n      padding: 8px;\n    }\n    .mobile-toggle span {\n      display: block;\n      width: 24px;\n      height: 1.5px;\n      background: var(--color-text);\n      margin: 5px 0;\n      transition: 0.3s;\n    }\n\n    /* ═══════════════════════════════════════\n       HERO SECTION\n    ═══════════════════════════════════════ */\n    .hero {\n      padding: 100px 0 80px;\n      text-align: center;\n      position: relative;\n    }\n    .hero::before {\n      content: '';\n      position: absolute;\n      top: 0;\n      left: 50%;\n      transform: translateX(-50%);\n      width: 1px;\n      height: 60px;\n      background: var(--color-line);\n    }\n    .hero-eyebrow {\n      font-size: 11px;\n      letter-spacing: 4px;\n      text-transform: uppercase;\n      color: var(--color-accent-dark);\n      font-weight: 500;\n      margin-bottom: 28px;\n      padding-top: 40px;\n      opacity: 0;\n      animation: fadeUp 0.8s ease 0.2s forwards;\n    }\n    .hero h1 {\n      font-family: var(--font-display);\n      font-size: clamp(38px, 5.5vw, 64px);\n      font-weight: 300;\n      line-height: 1.15;\n      color: var(--color-text);\n      margin-bottom: 28px;\n      opacity: 0;\n      animation: fadeUp 0.8s ease 0.4s forwards;\n    }\n    .hero h1 em {\n      font-style: italic;\n      font-weight: 400;\n    }\n    .hero-desc {\n      max-width: 620px;\n      margin: 0 auto;\n      font-size: 15px;\n      color: var(--color-text-muted);\n      line-height: 1.85;\n      opacity: 0;\n      animation: fadeUp 0.8s ease 0.6s forwards;\n    }\n\n    /* ═══════════════════════════════════════\n       SECTION COMMON\n    ═══════════════════════════════════════ */\n    .section {\n      padding: var(--section-spacing) 0;\n    }\n    .section-warm {\n      background: var(--color-bg-warm);\n    }\n    .section-deep {\n      background: var(--color-bg-deep);\n    }\n    .section-eyebrow {\n      font-size: 11px;\n      letter-spacing: 3.5px;\n      text-transform: uppercase;\n      color: var(--color-accent-dark);\n      font-weight: 500;\n      margin-bottom: 16px;\n    }\n    .section-title {\n      font-family: var(--font-display);\n      font-size: clamp(28px, 3.5vw, 44px);\n      font-weight: 300;\n      line-height: 1.25;\n      margin-bottom: 24px;\n    }\n    .section-title em { font-style: italic; font-weight: 400; }\n    .section-body {\n      font-size: 15px;\n      color: var(--color-text-muted);\n      line-height: 1.85;\n      max-width: 640px;\n    }\n\n    /* ═══════════════════════════════════════\n       SPLIT LAYOUT (image + text)\n    ═══════════════════════════════════════ */\n    .split {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 80px;\n      align-items: center;\n    }\n    .split.reverse .split-visual { order: 2; }\n    .split.reverse .split-content { order: 1; }\n\n    .split-visual {\n      position: relative;\n      border-radius: 4px;\n      overflow: hidden;\n    }\n    .visual-placeholder {\n      aspect-ratio: 4/5;\n      background: linear-gradient(135deg, var(--color-bg-deep) 0%, var(--color-line) 100%);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      border-radius: 4px;\n      position: relative;\n      overflow: hidden;\n    }\n    .visual-placeholder .icon-wrap {\n      text-align: center;\n      color: var(--color-text-light);\n      z-index: 1;\n    }\n    .visual-placeholder .icon-wrap svg {\n      width: 48px;\n      height: 48px;\n      stroke: var(--color-accent);\n      stroke-width: 1;\n      margin-bottom: 12px;\n    }\n    .visual-placeholder .icon-wrap p {\n      font-size: 12px;\n      letter-spacing: 2px;\n      text-transform: uppercase;\n      color: var(--color-text-light);\n    }\n\n    /* ═══════════════════════════════════════\n       CREDENTIAL BADGES\n    ═══════════════════════════════════════ */\n    .credentials {\n      display: grid;\n      grid-template-columns: repeat(4, 1fr);\n      gap: 24px;\n      margin-top: 60px;\n    }\n    .credential-card {\n      background: var(--color-white);\n      border: 1px solid var(--color-line);\n      border-radius: 4px;\n      padding: 36px 28px;\n      text-align: center;\n      transition: transform 0.4s ease, box-shadow 0.4s ease;\n    }\n    .credential-card:hover {\n      transform: translateY(-4px);\n      box-shadow: 0 12px 40px rgba(44, 40, 36, 0.06);\n    }\n    .credential-icon {\n      width: 52px;\n      height: 52px;\n      margin: 0 auto 20px;\n      border-radius: 50%;\n      background: var(--color-bg-warm);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n    .credential-icon svg {\n      width: 24px;\n      height: 24px;\n      stroke: var(--color-accent-dark);\n      stroke-width: 1.5;\n      fill: none;\n    }\n    .credential-card h4 {\n      font-family: var(--font-display);\n      font-size: 19px;\n      font-weight: 500;\n      margin-bottom: 8px;\n    }\n    .credential-card p {\n      font-size: 13px;\n      color: var(--color-text-muted);\n      line-height: 1.65;\n    }\n\n    /* ═══════════════════════════════════════\n       STABILITY DATA TABLE\n    ═══════════════════════════════════════ */\n    .stability-grid {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 40px;\n      margin-top: 48px;\n    }\n    .stability-card {\n      background: var(--color-white);\n      border: 1px solid var(--color-line);\n      border-radius: 4px;\n      overflow: hidden;\n    }\n    .stability-card-header {\n      padding: 24px 28px;\n      border-bottom: 1px solid var(--color-line);\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n    }\n    .stability-card-header h4 {\n      font-family: var(--font-display);\n      font-size: 20px;\n      font-weight: 500;\n    }\n    .badge {\n      display: inline-flex;\n      align-items: center;\n      gap: 6px;\n      font-size: 11px;\n      letter-spacing: 1px;\n      text-transform: uppercase;\n      font-weight: 500;\n      padding: 5px 12px;\n      border-radius: 20px;\n      background: var(--color-badge-green-bg);\n      color: var(--color-badge-green);\n    }\n    .badge svg {\n      width: 12px;\n      height: 12px;\n      stroke: var(--color-badge-green);\n      stroke-width: 2;\n      fill: none;\n    }\n    .stability-card-body { padding: 28px; }\n    .stability-card-body table {\n      width: 100%;\n      border-collapse: collapse;\n      font-size: 13px;\n    }\n    .stability-card-body th {\n      text-align: left;\n      font-weight: 500;\n      font-size: 11px;\n      letter-spacing: 1px;\n      text-transform: uppercase;\n      color: var(--color-text-light);\n      padding: 10px 0;\n      border-bottom: 1px solid var(--color-line);\n    }\n    .stability-card-body td {\n      padding: 12px 0;\n      border-bottom: 1px solid rgba(221,214,204,0.5);\n      color: var(--color-text-muted);\n    }\n    .stability-card-body tr:last-child td {\n      border-bottom: none;\n      font-weight: 500;\n      color: var(--color-text);\n    }\n\n    /* ═══════════════════════════════════════\n       INGREDIENT PHILOSOPHY\n    ═══════════════════════════════════════ */\n    .philosophy-grid {\n      display: grid;\n      grid-template-columns: repeat(3, 1fr);\n      gap: 32px;\n      margin-top: 48px;\n    }\n    .philosophy-item {\n      padding: 40px 32px;\n      border: 1px solid var(--color-line);\n      border-radius: 4px;\n      background: var(--color-white);\n      position: relative;\n      overflow: hidden;\n    }\n    .philosophy-item::before {\n      content: '';\n      position: absolute;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 2px;\n      background: linear-gradient(90deg, var(--color-accent), transparent);\n    }\n    .philosophy-item h4 {\n      font-family: var(--font-display);\n      font-size: 22px;\n      font-weight: 400;\n      margin-bottom: 12px;\n    }\n    .philosophy-item p {\n      font-size: 14px;\n      color: var(--color-text-muted);\n      line-height: 1.75;\n    }\n\n    /* ═══════════════════════════════════════\n       CTA BANNER\n    ═══════════════════════════════════════ */\n    .cta-banner {\n      text-align: center;\n      padding: 80px 40px;\n      background: var(--color-text);\n      color: var(--color-white);\n    }\n    .cta-banner .section-eyebrow { color: var(--color-accent); }\n    .cta-banner .section-title {\n      color: var(--color-white);\n      margin-bottom: 16px;\n    }\n    .cta-banner p {\n      color: rgba(255,255,255,0.65);\n      max-width: 500px;\n      margin: 0 auto 32px;\n      font-size: 15px;\n    }\n    .cta-btn {\n      display: inline-block;\n      padding: 14px 42px;\n      border: 1px solid var(--color-accent);\n      color: var(--color-accent);\n      font-size: 12px;\n      letter-spacing: 2px;\n      text-transform: uppercase;\n      font-weight: 500;\n      transition: background 0.4s, color 0.4s;\n      border-radius: 2px;\n    }\n    .cta-btn:hover {\n      background: var(--color-accent);\n      color: var(--color-text);\n    }\n\n    /* ═══════════════════════════════════════\n       TIMELINE\n    ═══════════════════════════════════════ */\n    .timeline {\n      position: relative;\n      margin-top: 48px;\n      padding-left: 40px;\n    }\n    .timeline::before {\n      content: '';\n      position: absolute;\n      top: 0;\n      left: 11px;\n      width: 1px;\n      height: 100%;\n      background: var(--color-line);\n    }\n    .timeline-item {\n      position: relative;\n      padding-bottom: 40px;\n      padding-left: 36px;\n    }\n    .timeline-item:last-child { padding-bottom: 0; }\n    .timeline-dot {\n      position: absolute;\n      left: -40px;\n      top: 4px;\n      width: 22px;\n      height: 22px;\n      border-radius: 50%;\n      background: var(--color-bg);\n      border: 2px solid var(--color-accent);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n    .timeline-dot::after {\n      content: '';\n      width: 8px;\n      height: 8px;\n      border-radius: 50%;\n      background: var(--color-accent);\n    }\n    .timeline-item h4 {\n      font-family: var(--font-display);\n      font-size: 20px;\n      font-weight: 500;\n      margin-bottom: 6px;\n    }\n    .timeline-item p {\n      font-size: 14px;\n      color: var(--color-text-muted);\n      line-height: 1.75;\n    }\n\n    /* ═══════════════════════════════════════\n       DOC REQUEST CALLOUT\n    ═══════════════════════════════════════ */\n    .doc-callout {\n      margin-top: 48px;\n      padding: 32px 36px;\n      background: var(--color-white);\n      border: 1px solid var(--color-line);\n      border-radius: 4px;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 24px;\n    }\n    .doc-callout-text h4 {\n      font-family: var(--font-display);\n      font-size: 20px;\n      font-weight: 400;\n      margin-bottom: 4px;\n    }\n    .doc-callout-text p {\n      font-size: 13px;\n      color: var(--color-text-muted);\n    }\n    .doc-callout .cta-btn {\n      white-space: nowrap;\n      border-color: var(--color-text);\n      color: var(--color-text);\n      padding: 12px 32px;\n      flex-shrink: 0;\n    }\n    .doc-callout .cta-btn:hover {\n      background: var(--color-text);\n      color: var(--color-white);\n    }\n\n    /* ═══════════════════════════════════════\n       FOOTER (simplified match)\n    ═══════════════════════════════════════ */\n    .site-footer {\n      border-top: 1px solid var(--color-line);\n      padding: 60px 0 40px;\n      font-size: 13px;\n      color: var(--color-text-muted);\n    }\n    .footer-grid {\n      display: grid;\n      grid-template-columns: 2fr 1fr 1fr 1fr;\n      gap: 40px;\n      margin-bottom: 40px;\n    }\n    .footer-brand h3 {\n      font-family: var(--font-display);\n      font-size: 24px;\n      font-weight: 400;\n      color: var(--color-text);\n      margin-bottom: 12px;\n    }\n    .footer-col h5 {\n      font-size: 11px;\n      letter-spacing: 2px;\n      text-transform: uppercase;\n      font-weight: 500;\n      color: var(--color-text);\n      margin-bottom: 16px;\n    }\n    .footer-col ul {\n      list-style: none;\n    }\n    .footer-col li { margin-bottom: 8px; }\n    .footer-col a { transition: color 0.3s; }\n    .footer-col a:hover { color: var(--color-accent-dark); }\n    .footer-bottom {\n      border-top: 1px solid var(--color-line);\n      padding-top: 24px;\n      text-align: center;\n      font-size: 12px;\n      color: var(--color-text-light);\n    }\n\n    /* ═══════════════════════════════════════\n       ANIMATIONS\n    ═══════════════════════════════════════ */\n    @keyframes fadeUp {\n      from { opacity: 0; transform: translateY(20px); }\n      to { opacity: 1; transform: translateY(0); }\n    }\n    .reveal {\n      opacity: 0;\n      transform: translateY(30px);\n      transition: opacity 0.8s ease, transform 0.8s ease;\n    }\n    .reveal.visible {\n      opacity: 1;\n      transform: translateY(0);\n    }\n\n    /* ═══════════════════════════════════════\n       RESPONSIVE\n    ═══════════════════════════════════════ */\n    @media (max-width: 1024px) {\n      .container { padding: 0 28px; }\n      .split { grid-template-columns: 1fr; gap: 48px; }\n      .split.reverse .split-visual { order: 0; }\n      .split.reverse .split-content { order: 0; }\n      .credentials { grid-template-columns: repeat(2, 1fr); }\n      .stability-grid { grid-template-columns: 1fr; }\n      .footer-grid { grid-template-columns: 1fr 1fr; }\n    }\n\n    @media (max-width: 768px) {\n      :root { --section-spacing: 80px; }\n      .nav-links { display: none; }\n      .mobile-toggle { display: block; }\n      .hero { padding: 80px 0 60px; }\n      .hero::before { height: 40px; }\n      .credentials { grid-template-columns: 1fr; }\n      .philosophy-grid { grid-template-columns: 1fr; }\n      .doc-callout { flex-direction: column; text-align: center; }\n      .footer-grid { grid-template-columns: 1fr; gap: 32px; }\n      .split { gap: 36px; }\n    }\n  </style>\n</head>\n<body>\n\n  <!-- ═══════════ ANNOUNCEMENT BAR ═══════════ -->\n  <div class=\"announcement-bar\">\n    Complimentary shipping on all domestic orders within India\n  </div>\n\n  <!-- ═══════════ HEADER ═══════════ -->\n  <header class=\"site-header\">\n    <div class=\"container\">\n      <a href=\"https://ferafive.com/\" class=\"logo-text\">f<span>é</span>rafive</a>\n      <nav>\n        <ul class=\"nav-links\">\n          <li><a href=\"https://ferafive.com/\">Home</a></li>\n          <li><a href=\"https://ferafive.com/products/crush-for-her-100ml\">Perfume</a></li>\n          <li><a href=\"https://ferafive.com/products/hydrafusion-moisturiser\">Moisturiser</a></li>\n          <li><a href=\"https://ferafive.com/products/hydrafusion-serum\">Serum</a></li>\n          <li><a href=\"https://ferafive.com/pages/about-us\">About Us</a></li>\n          <li><a href=\"#\" class=\"active\">Our Standards</a></li>\n          <li><a href=\"https://ferafive.com/pages/contact\">Contact</a></li>\n        </ul>\n      </nav>\n      <button class=\"mobile-toggle\" aria-label=\"Menu\">\n        <span></span><span></span><span></span>\n      </button>\n    </div>\n  </header>\n\n  <!-- ═══════════ HERO ═══════════ -->\n  <section class=\"hero\">\n    <div class=\"container\">\n      <p class=\"hero-eyebrow\">Our Standards</p>\n      <h1>The <em>Promise</em> Behind<br>Every Product</h1>\n      <p class=\"hero-desc\">\n        We believe transparency is a form of respect. Every férafive product is \n        licensed, stability-tested, and manufactured to exacting standards — \n        because what you put on your skin should be worthy of your trust.\n      </p>\n    </div>\n  </section>\n\n  <!-- ═══════════ CREDENTIALS (BADGES) ═══════════ -->\n  <section class=\"section section-warm\">\n    <div class=\"container\">\n      <div style=\"text-align:center;\" class=\"reveal\">\n        <p class=\"section-eyebrow\">Certified & Verified</p>\n        <h2 class=\"section-title\">Built on <em>credentials</em>, not claims</h2>\n      </div>\n      <div class=\"credentials reveal\">\n\n        <div class=\"credential-card\">\n          <div class=\"credential-icon\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M9 12l2 2 4-4\"/><path d=\"M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z\"/></svg>\n          </div>\n          <h4>FDA Licensed</h4>\n          <p>All products approved under India's Drugs &amp; Cosmetics Act, 1940. Certificate No. PD031818P.</p>\n        </div>\n\n        <div class=\"credential-card\">\n          <div class=\"credential-icon\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M12 2L2 7l10 5 10-5-10-5z\"/><path d=\"M2 17l10 5 10-5\"/><path d=\"M2 12l10 5 10-5\"/></svg>\n          </div>\n          <h4>ISO 9001</h4>\n          <p>Manufactured at an ISO 9001 certified facility following international quality management systems.</p>\n        </div>\n\n        <div class=\"credential-card\">\n          <div class=\"credential-icon\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n          </div>\n          <h4>GMP Certified</h4>\n          <p>Produced under Good Manufacturing Practice standards, ensuring consistent quality at every batch.</p>\n        </div>\n\n        <div class=\"credential-card\">\n          <div class=\"credential-icon\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z\"/></svg>\n          </div>\n          <h4>Cruelty-Free & Vegan</h4>\n          <p>No animal testing. No animal-derived ingredients. Clean formulations grounded in intention.</p>\n        </div>\n\n      </div>\n    </div>\n  </section>\n\n  <!-- ═══════════ FDA LICENSING STORY ═══════════ -->\n  <section class=\"section\">\n    <div class=\"container\">\n      <div class=\"split reveal\">\n        <div class=\"split-visual\">\n          <div class=\"visual-placeholder\">\n            <div class=\"icon-wrap\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"/><polyline points=\"14 2 14 8 20 8\"/><line x1=\"16\" y1=\"13\" x2=\"8\" y2=\"13\"/><line x1=\"16\" y1=\"17\" x2=\"8\" y2=\"17\"/><polyline points=\"10 9 9 9 8 9\"/></svg>\n              <p>FDA Certificate</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"split-content\">\n          <p class=\"section-eyebrow\">Regulatory Approval</p>\n          <h2 class=\"section-title\">Licensed under the Drugs &amp; <em>Cosmetics Act</em></h2>\n          <div class=\"section-body\">\n            <p>\n              Every férafive product — the Hydrafusion Moisturiser, Hydrashot Serum, and Crush perfume — \n              is formally approved by the Food Safety &amp; Drug Administration, Uttar Pradesh, under \n              Licence No. UP16320000028 (Certificate No. PD031818P, dated October 2025).\n            </p>\n            <br>\n            <p>\n              This isn't a decorative seal. It means our formulations, packaging, and manufacturing \n              processes have been reviewed and cleared by a state licensing authority. It means \n              every product you use meets the legal standards required for cosmetics sold in India.\n            </p>\n            <br>\n            <p>\n              Our manufacturing partner, A.G. Organica Pvt. Ltd., holds this licence and operates \n              from their facility at Sector-85, Noida — a certified unit with ISO 9001, GMP, \n              Halal, and FSSAI credentials.\n            </p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- ═══════════ STABILITY TESTING ═══════════ -->\n  <section class=\"section section-warm\">\n    <div class=\"container\">\n      <div class=\"split reverse reveal\">\n        <div class=\"split-content\">\n          <p class=\"section-eyebrow\">Stability Tested</p>\n          <h2 class=\"section-title\">90 days under <em>extreme</em> conditions</h2>\n          <div class=\"section-body\">\n            <p>\n              Before any férafive product reaches you, it endures 90 days of accelerated stability \n              testing at 40°C and 75% relative humidity — conditions far harsher than typical Indian \n              summers.\n            </p>\n            <br>\n            <p>\n              We test for appearance, colour, odour, pH balance, viscosity, specific gravity, \n              centrifugation stability, and overall product integrity. Every parameter must remain \n              within specification at each checkpoint: 14 days, 21 days, 45 days, and 90 days.\n            </p>\n            <br>\n            <p>\n              The result? Products that perform consistently in your climate, \n              your routine, and your life — from the first use to the last drop.\n            </p>\n          </div>\n        </div>\n        <div class=\"split-visual\">\n          <div class=\"visual-placeholder\">\n            <div class=\"icon-wrap\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><path d=\"M14 2v6h6\"/><path d=\"M4 2h10l6 6v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z\"/><path d=\"M8 18v-6\"/><path d=\"M12 18v-4\"/><path d=\"M16 18v-8\"/></svg>\n              <p>Stability Report</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Data Tables -->\n      <div class=\"stability-grid reveal\">\n        <!-- Hydrafusion Moisturiser -->\n        <div class=\"stability-card\">\n          <div class=\"stability-card-header\">\n            <h4>Hydrafusion Moisturiser</h4>\n            <span class=\"badge\">\n              <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n              All Pass\n            </span>\n          </div>\n          <div class=\"stability-card-body\">\n            <table>\n              <thead>\n                <tr>\n                  <th>Checkpoint</th>\n                  <th>pH</th>\n                  <th>Viscosity (Pa.s)</th>\n                  <th>Sp. Gravity</th>\n                </tr>\n              </thead>\n              <tbody>\n                <tr><td>Specification</td><td>5.00 – 6.00</td><td>5.80 – 6.50</td><td>0.99 – 1.05</td></tr>\n                <tr><td>Initial</td><td>5.60</td><td>6.10</td><td>1.0150</td></tr>\n                <tr><td>14 days</td><td>5.62</td><td>6.15</td><td>1.0152</td></tr>\n                <tr><td>21 days</td><td>5.60</td><td>6.18</td><td>1.0157</td></tr>\n                <tr><td>45 days</td><td>5.57</td><td>6.21</td><td>1.0151</td></tr>\n                <tr><td>90 days</td><td>5.65</td><td>6.27</td><td>1.0158</td></tr>\n              </tbody>\n            </table>\n          </div>\n        </div>\n        <!-- Intense Hydration Serum -->\n        <div class=\"stability-card\">\n          <div class=\"stability-card-header\">\n            <h4>Hydrashot Serum</h4>\n            <span class=\"badge\">\n              <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n              All Pass\n            </span>\n          </div>\n          <div class=\"stability-card-body\">\n            <table>\n              <thead>\n                <tr>\n                  <th>Checkpoint</th>\n                  <th>pH</th>\n                  <th>Sp. Gravity</th>\n                  <th>Status</th>\n                </tr>\n              </thead>\n              <tbody>\n                <tr><td>Specification</td><td>4.50 – 5.00</td><td>1.02 – 1.07</td><td>—</td></tr>\n                <tr><td>Initial</td><td>4.65</td><td>1.0385</td><td>Complies</td></tr>\n                <tr><td>14 days</td><td>4.69</td><td>1.0388</td><td>Complies</td></tr>\n                <tr><td>21 days</td><td>4.72</td><td>1.0392</td><td>Complies</td></tr>\n                <tr><td>45 days</td><td>4.66</td><td>1.0380</td><td>Complies</td></tr>\n                <tr><td>90 days</td><td>4.75</td><td>1.0383</td><td>Complies</td></tr>\n              </tbody>\n            </table>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- ═══════════ MANUFACTURING PARTNER ═══════════ -->\n  <section class=\"section\">\n    <div class=\"container\">\n      <div class=\"split reveal\">\n        <div class=\"split-visual\">\n          <div class=\"visual-placeholder\" style=\"aspect-ratio:5/4;\">\n            <div class=\"icon-wrap\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><rect x=\"2\" y=\"7\" width=\"20\" height=\"14\" rx=\"2\"/><path d=\"M16 3h-8l-2 4h12l-2-4z\"/><circle cx=\"12\" cy=\"14\" r=\"3\"/></svg>\n              <p>Manufacturing Facility</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"split-content\">\n          <p class=\"section-eyebrow\">Our Manufacturing Partner</p>\n          <h2 class=\"section-title\">A.G. Organica <em>Pvt. Ltd.</em></h2>\n          <div class=\"section-body\">\n            <p>\n              Our products are formulated and manufactured by A.G. Organica, a certified cosmetics \n              manufacturer based in Noida, Uttar Pradesh. Their facility operates under a comprehensive \n              set of quality certifications that ensure every batch meets rigorous standards.\n            </p>\n          </div>\n\n          <div class=\"timeline\" style=\"margin-top: 36px;\">\n            <div class=\"timeline-item\">\n              <div class=\"timeline-dot\"></div>\n              <h4>ISO 9001 Certified</h4>\n              <p>International quality management systems governing every production process.</p>\n            </div>\n            <div class=\"timeline-item\">\n              <div class=\"timeline-dot\"></div>\n              <h4>GMP Compliant</h4>\n              <p>Good Manufacturing Practice protocols ensuring hygiene, consistency, and traceability.</p>\n            </div>\n            <div class=\"timeline-item\">\n              <div class=\"timeline-dot\"></div>\n              <h4>Halal Certified</h4>\n              <p>Ingredients and processes verified to meet Halal standards.</p>\n            </div>\n            <div class=\"timeline-item\">\n              <div class=\"timeline-dot\"></div>\n              <h4>FSSAI Registered</h4>\n              <p>Compliant with India's food safety and standards authority for applicable ingredients.</p>\n            </div>\n            <div class=\"timeline-item\">\n              <div class=\"timeline-dot\"></div>\n              <h4>ISO 22000 & OneCert Organic</h4>\n              <p>Additional certifications for safety management and organic ingredient sourcing.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- ═══════════ INGREDIENT PHILOSOPHY ═══════════ -->\n  <section class=\"section section-warm\">\n    <div class=\"container\">\n      <div style=\"text-align:center;\" class=\"reveal\">\n        <p class=\"section-eyebrow\">Ingredient Philosophy</p>\n        <h2 class=\"section-title\">What goes in. <em>What stays out.</em></h2>\n        <p class=\"section-body\" style=\"max-width:560px;margin:0 auto;\">\n          We formulate with intention. Every ingredient earns its place — chosen for \n          long-term skin transformation, not instant-gratification marketing.\n        </p>\n      </div>\n      <div class=\"philosophy-grid reveal\">\n\n        <div class=\"philosophy-item\">\n          <h4>Purposeful Actives</h4>\n          <p>\n            Niacinamide, Sodium Hyaluronate, Squalane, Ceramide, Vitamin C, and Alpha Arbutin — \n            each selected for proven efficacy in hydration, barrier repair, and tone correction.\n          </p>\n        </div>\n\n        <div class=\"philosophy-item\">\n          <h4>Botanical Intelligence</h4>\n          <p>\n            Aloe Vera, Mulberry, Licorice, Mushroom, and Tea Tree extracts work in concert — \n            soothing, brightening, and protecting without overwhelming the skin.\n          </p>\n        </div>\n\n        <div class=\"philosophy-item\">\n          <h4>Clean by Design</h4>\n          <p>\n            Paraben-free. Cruelty-free. Vegan. No harsh sulphates. \n            We don't formulate for trends — we formulate for trust.\n          </p>\n        </div>\n\n      </div>\n    </div>\n  </section>\n\n  <!-- ═══════════ BATCH QUALITY ═══════════ -->\n  <section class=\"section\">\n    <div class=\"container\">\n      <div class=\"split reverse reveal\">\n        <div class=\"split-content\">\n          <p class=\"section-eyebrow\">Batch-Level Quality</p>\n          <h2 class=\"section-title\">Every batch is <em>individually analysed</em></h2>\n          <div class=\"section-body\">\n            <p>\n              Before any product leaves the facility, a Certificate of Analysis is issued for that \n              specific batch. Each certificate records test results for appearance, colour, odour, pH, \n              specific gravity, viscosity, and centrifugation — signed off by both the Q.C. Executive \n              and the Assistant Manager of Quality Control.\n            </p>\n            <br>\n            <p>\n              This isn't a formality. It's our guarantee that the product in your hands has been \n              individually verified — not just assumed to be correct because the formula was approved once.\n            </p>\n          </div>\n        </div>\n        <div class=\"split-visual\">\n          <div class=\"visual-placeholder\" style=\"aspect-ratio:4/4;\">\n            <div class=\"icon-wrap\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><path d=\"M9 11l3 3L22 4\"/><path d=\"M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11\"/></svg>\n              <p>Certificate of Analysis</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Doc Request -->\n      <div class=\"doc-callout reveal\">\n        <div class=\"doc-callout-text\">\n          <h4>Need the full documentation?</h4>\n          <p>We're happy to share our stability reports, MSDS sheets, and certificates of analysis upon request.</p>\n        </div>\n        <a href=\"mailto:contact@ferafive.com?subject=Documentation%20Request%20-%20F%C3%A9raFive%20Products\" class=\"cta-btn\">Request via Email</a>\n      </div>\n    </div>\n  </section>\n\n  <!-- ═══════════ CTA BANNER ═══════════ -->\n  <section class=\"cta-banner\">\n    <div class=\"container\">\n      <p class=\"section-eyebrow\">The Férafive Promise</p>\n      <h2 class=\"section-title\">Quality you can feel. <em>Standards you can trust.</em></h2>\n      <p>Three products. One philosophy. Zero compromises.</p>\n      <a href=\"https://ferafive.com/collections/bestseller\" class=\"cta-btn\">Explore the Collection</a>\n    </div>\n  </section>\n\n  <!-- ═══════════ FOOTER ═══════════ -->\n  <footer class=\"site-footer\">\n    <div class=\"container\">\n      <div class=\"footer-grid\">\n        <div class=\"footer-brand\">\n          <h3>f<span style=\"font-style:italic;\">é</span>rafive</h3>\n          <p>Luxury skincare brand for modern rituals. Where beauty is a practice of presence, not performance.</p>\n        </div>\n        <div class=\"footer-col\">\n          <h5>Shop</h5>\n          <ul>\n            <li><a href=\"https://ferafive.com/products/crush-for-her-100ml\">Perfume</a></li>\n            <li><a href=\"https://ferafive.com/products/hydrafusion-moisturiser\">Moisturiser</a></li>\n            <li><a href=\"https://ferafive.com/products/hydrafusion-serum\">Serum</a></li>\n          </ul>\n        </div>\n        <div class=\"footer-col\">\n          <h5>Company</h5>\n          <ul>\n            <li><a href=\"https://ferafive.com/pages/about-us\">About Us</a></li>\n            <li><a href=\"#\">Our Standards</a></li>\n            <li><a href=\"https://ferafive.com/pages/contact\">Contact</a></li>\n          </ul>\n        </div>\n        <div class=\"footer-col\">\n          <h5>Policy</h5>\n          <ul>\n            <li><a href=\"https://ferafive.com/policies/privacy-policy\">Privacy Policy</a></li>\n            <li><a href=\"https://ferafive.com/policies/refund-policy\">Refund Policy</a></li>\n            <li><a href=\"https://ferafive.com/policies/shipping-policy\">Shipping Policy</a></li>\n            <li><a href=\"https://ferafive.com/policies/terms-of-service\">Terms of Service</a></li>\n          </ul>\n        </div>\n      </div>\n      <div class=\"footer-bottom\">\n        &copy; 2026 – férafive (FOSL Films (OPC) Private Limited). All rights reserved.\n      </div>\n    </div>\n  </footer>\n\n  <!-- ═══════════ SCROLL REVEAL JS ═══════════ -->\n  <script>\n    document.addEventListener('DOMContentLoaded', () => {\n      const reveals = document.querySelectorAll('.reveal');\n      const observer = new IntersectionObserver((entries) => {\n        entries.forEach(entry => {\n          if (entry.isIntersecting) {\n            entry.target.classList.add('visible');\n          }\n        });\n      }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });\n\n      reveals.forEach(el => observer.observe(el));\n\n      // Mobile nav toggle (basic)\n      const toggle = document.querySelector('.mobile-toggle');\n      const navLinks = document.querySelector('.nav-links');\n      if (toggle) {\n        toggle.addEventListener('click', () => {\n          navLinks.style.display = navLinks.style.display === 'flex' ? 'none' : 'flex';\n          navLinks.style.flexDirection = 'column';\n          navLinks.style.position = 'absolute';\n          navLinks.style.top = '100%';\n          navLinks.style.left = '0';\n          navLinks.style.right = '0';\n          navLinks.style.background = 'var(--color-bg)';\n          navLinks.style.padding = '20px 28px';\n          navLinks.style.borderBottom = '1px solid var(--color-line)';\n          navLinks.style.gap = '16px';\n        });\n      }\n    });\n  </script>\n\n</body>\n</html>",
        "text_alignment": "center"
      }
    }
