{% doc %}
  @prompt
    Create a section for the footer where that show that we accept all kind of payment Visa, mastercard and all include UPI as well
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-payment-methods-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.alignment }};
  }

  .ai-payment-methods__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.spacing_below_heading }}px 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    text-transform: {{ block.settings.heading_transform }};
  }

  .ai-payment-methods__icons-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.icon_spacing }}px;
    {% if block.settings.alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
    align-items: center;
  }

  .ai-payment-methods__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_width }}px;
    height: {{ block.settings.icon_height }}px;
    background-color: {{ block.settings.icon_background }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.icon_padding }}px;
    border: {{ block.settings.icon_border_width }}px solid {{ block.settings.icon_border_color }};
  }

  .ai-payment-methods__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media screen and (max-width: 749px) {
    .ai-payment-methods__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_width | times: 0.8 }}px;
      height: {{ block.settings.icon_height | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-payment-methods-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h3 class="ai-payment-methods__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
  {% endif %}

  <div class="ai-payment-methods__icons-{{ ai_gen_id }}">
    {% if block.settings.show_visa %}
